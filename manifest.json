{
    "name": "ять fix",
    "description": "Converts text typed in the wrong keyboard layout and more. It works in input, textarea, and most custom fields. You can convert selected or full text. Includes automatic correction with context menu controls and per-site exclusions.",
    "version": "1.6",
    "manifest_version": 3,

    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },

    "permissions": [
        "storage",
        "tabs",
        "commands",
        "contextMenus"
    ],
    
    "background": {
        "service_worker": "background.js"
    },

    "commands": {
        "change-layout": {
            "suggested_key": {
                "default": "Alt+X",
                "mac": "Alt+X"
            },
            "description": "Changes text layout (language)"
        },
        "change-register": {
            "suggested_key": {
                "default": "Alt+Z",
                "mac": "Alt+Z"
            },
            "description": "Changes text register"
        }
    },
    
    "content_scripts": [{
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "run_at": "document_idle"
    }]
    
}
